# Maintainer: rustyraven <rustyraven@extera.xyz>
pkgname=extera-next-git
pkgver=26.0.8
pkgrel=1
pkgdesc="Matrix client - Chat with your friends (fork of FluffyChat)"
arch=('x86_64')
url="https://github.com/ExteraApp/Extera"
license=('AGPL-3.0-only')
depends=(
    'gtk3'
    'libsecret'
    'jsoncpp'
    'openssl'
    'libpciaccess',
    'libkeybinder3'
)
makedepends=(
    'flutter'
    'git'
    'cmake'
    'ninja'
    'clang'
    'pkgconf'
    'curl'
    'rust'
    'cargo'
)
provides=('extera-next')
conflicts=('extera-next')
source=("${pkgname}::git+https://github.com/ExteraApp/Extera.git")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/$pkgname"
    git describe --long --tags 2>/dev/null | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g' || \
    printf "%s.r%s.%s" "$(grep '^version:' pubspec.yaml | head -1 | awk '{print $2}')" \
        "$(git rev-list --count HEAD)" \
        "g$(git rev-parse --short HEAD)"
}

build() {
    cd "$srcdir/$pkgname"

    # Build the Flutter Linux release
    flutter build linux --release
}

package() {
    cd "$srcdir/$pkgname"

    # Install the bundle to /opt/extera-next
    install -dm755 "$pkgdir/opt/extera-next"
    cp -r build/linux/x64/release/bundle/* "$pkgdir/opt/extera-next/"

    # Set proper permissions
    chmod 755 "$pkgdir/opt/extera-next/extera_next"

    # Create a wrapper script in /usr/bin
    install -dm755 "$pkgdir/usr/bin"
    cat > "$pkgdir/usr/bin/extera-next" << 'EOF'
#!/bin/bash
exec /opt/extera-next/extera_next "$@"
EOF
    chmod 755 "$pkgdir/usr/bin/extera-next"

    # Install desktop file
    install -Dm644 "$srcdir/$pkgname/aur/extera.desktop" \
        "$pkgdir/usr/share/applications/xyz.extera.next.desktop"

    # Install icon
    install -Dm644 "$srcdir/$pkgname/assets/logo.png" \
        "$pkgdir/usr/share/icons/hicolor/512x512/apps/extera.png"

    # Install license
    install -Dm644 "$srcdir/$pkgname/LICENSE" \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
